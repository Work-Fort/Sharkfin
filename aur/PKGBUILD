# Maintainer: Kaz Walker <me@kazatron.com>
pkgname=sharkfin-bin
pkgver=0.0.0
pkgrel=1
pkgdesc='LLM IPC tool for coding agent collaboration via MCP'
arch=('x86_64' 'aarch64')
url='https://github.com/Work-Fort/sharkfin'
license=('GPL-2.0-only')
provides=('sharkfin')
conflicts=('sharkfin')

source=('sharkfin.service')
source_x86_64=("${url}/releases/download/v${pkgver}/sharkfin-v${pkgver}-linux-amd64.tar.gz")
source_aarch64=("${url}/releases/download/v${pkgver}/sharkfin-v${pkgver}-linux-arm64.tar.gz")
sha256sums=('SKIP')
sha256sums_x86_64=('SKIP')
sha256sums_aarch64=('SKIP')

package() {
    local _archdir
    case "$CARCH" in
        x86_64)  _archdir="sharkfin-v${pkgver}-linux-amd64" ;;
        aarch64) _archdir="sharkfin-v${pkgver}-linux-arm64" ;;
    esac

    install -Dm755 "${_archdir}/sharkfin" "${pkgdir}/usr/bin/sharkfin"
    install -Dm644 sharkfin.service "${pkgdir}/usr/lib/systemd/user/sharkfin.service"
}
