#!/usr/bin/env bash
# SPDX-License-Identifier: AGPL-3.0-or-later
#MISE description="Build sharkfin"
#MISE sources=["**/*.go", "**/*.sql", "go.mod", "go.sum"]
#MISE outputs=["build/sharkfin"]
set -euo pipefail

BUILD_DIR=build
BINARY_NAME=sharkfin
GIT_SHORT_SHA=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
VERSION="${VERSION:-dev-$GIT_SHORT_SHA}"

mkdir -p "$BUILD_DIR"

go build -ldflags "-X github.com/Work-Fort/sharkfin/cmd.Version=$VERSION" -o "$BUILD_DIR/$BINARY_NAME"
echo "Built $BUILD_DIR/$BINARY_NAME"
